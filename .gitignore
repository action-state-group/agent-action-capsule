__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.DS_Store

# kramdown-rfc reference cache + v2 build intermediate
spec/.refcache/
spec/.draft-*.v2.xml

# never commit keys or demo artifacts
*.pem
*.cose

# test vectors are FROZEN committed bytes — exempt from the key/artifact ignore
!test-vectors/**/*.cose
!test-vectors/**/*.pem
