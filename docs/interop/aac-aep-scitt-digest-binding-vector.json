        "bound_digest": "response_digest",
        "bound_digest_raw_b64": "JIzdCCf2bSrF36Rs+1jV0KSMJUojfORCKkNF8ztT9W4=",
        "profile_label": "urn:action-state:aep-only:digest-binding:2026-07-02"
      },
      "expected_error": "profile_label_mismatch"
    },
    {
      "id": "noncanonical_json_input",
      "description": "The response digest is computed over pretty-printed JSON bytes instead of the JCS canonical output preimage.",
