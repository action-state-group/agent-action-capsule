      "expected_error": "digest_binding_encoding_mismatch"
    },
    {
      "id": "different_digest_bytes_in_quote",
      "description": "The AEP quote binds 32 raw bytes, but they are not the response_digest bytes from the capsule.",
      "mutated": {
        "bound_digest": "response_digest",
        "bound_digest_raw_b64": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
        "profile_label": "urn:action-state:aac-aep-scitt:digest-binding:2026-07-02"
